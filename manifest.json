{
  "manifest_version": 3,
  "name": "Unicode Text Converter",
  "version": "1.0.0",
  "description": "Highlight text, convert it into Unicode styled text locally, then replace, insert, or copy it.",
  "permissions": ["storage", "contextMenus", "clipboardWrite"],
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "action": {
    "default_title": "Unicode Text Converter",
    "default_popup": "popup.html"
  },
  "commands": {
    "open-style-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Open the Unicode style picker for the current selection"
    },
    "apply-last-style": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Apply the last used Unicode style instantly"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content-script.js"],
      "css": ["styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
